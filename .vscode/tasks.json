{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-raylib",
      "type": "shell",
      "command": "gcc",
      "args": [
        "main.c",
        "-o",
        "main.exe",
        "-IC:/raylib/include",
        "-LC:/raylib/lib",
        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm",
        "-mconsole"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}